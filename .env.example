TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_BOT_USERNAME=
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_DEV_GUILD_ID=
DATABASE_PROVIDER=sqlite
DATABASE_PATH=.data/agentcash-telegram.db
# Postgres is a migration scaffold only today. DATABASE_PROVIDER=postgres is not a runtime app mode yet.
DATABASE_URL=
ALLOW_SQLITE_IN_PRODUCTION=false
LOCK_PROVIDER=local
REDIS_URL=
ALLOW_LOCAL_LOCKS_IN_PRODUCTION=false
AUDIT_SINK=database
# When true, /readyz fails if the configured external audit sink cannot accept events.
AUDIT_STRICT_MODE=false
AUDIT_FILE_PATH=.data/audit-events.jsonl
AUDIT_HTTP_ENDPOINT=
ALLOW_DATABASE_AUDIT_IN_PRODUCTION=false
LOG_LEVEL=info
ALLOW_VERBOSE_LOGS_IN_PRODUCTION=false
NODE_ENV=development
BOT_MODE=polling
WEBHOOK_DOMAIN=
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=3000
WEBHOOK_SECRET_TOKEN=
HEALTH_HOST=0.0.0.0
HEALTH_PORT=3001
AGENTCASH_COMMAND=npx
# Pin the AgentCash CLI. Do not use a floating latest dist tag for demos or release builds;
# version drift can change wallet/check/fetch behavior overnight.
# This repo was last validated with agentcash@0.14.3.
AGENTCASH_ARGS=agentcash@0.14.3
AGENTCASH_TIMEOUT_MS=120000
DEFAULT_SPEND_CAP_USDC=0.5
HARD_SPEND_CAP_USDC=5
ALLOW_HIGH_VALUE_CALLS=false
ALLOW_UNQUOTED_DEV_CALLS=false
SKIP_AGENTCASH_HEALTHCHECK=false
CUSTODY_MODE=local_cli
ALLOW_INSECURE_LOCAL_CUSTODY=false
REMOTE_SIGNER_URL=
PENDING_CONFIRMATION_TTL_SECONDS=300
RATE_LIMIT_MAX_PER_MINUTE=30
RATE_LIMIT_MAX_PER_HOUR=100
RATE_LIMIT_QUOTE_MAX_PER_MINUTE=8
RATE_LIMIT_PAID_EXECUTION_MAX_PER_MINUTE=3
RATE_LIMIT_REPLAY_MAX_PER_HOUR=10
GLOBAL_PAID_CALL_CONCURRENCY=4
GROUP_DAILY_CAP_USDC=25
AGENTCASH_HOME_ROOT=data/agentcash-homes
OPENAI_API_KEY=
OPENAI_ROUTER_MODEL=gpt-5.4-mini
ANTHROPIC_API_KEY=
ANTHROPIC_ROUTER_MODEL=claude-sonnet-4-20250514
ROUTER_CONFIDENCE_THRESHOLD=0.75
ROUTER_TIMEOUT_MS=10000
# Must be a base64 string that decodes to exactly 32 bytes.
# Generate with: openssl rand -base64 32
MASTER_ENCRYPTION_KEY=replace-with-32-byte-base64-key
