TELEGRAM_BOT_TOKEN=replace-me
DATABASE_PATH=.data/agentcash-telegram.db
LOG_LEVEL=info
BOT_MODE=polling
WEBHOOK_DOMAIN=
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=3000
WEBHOOK_SECRET_TOKEN=
AGENTCASH_COMMAND=npx
AGENTCASH_ARGS=agentcash@latest
AGENTCASH_TIMEOUT_MS=120000
DEFAULT_SPEND_CAP_USDC=0.5
HARD_SPEND_CAP_USDC=5
ALLOW_HIGH_VALUE_CALLS=false
PENDING_CONFIRMATION_TTL_SECONDS=300
RATE_LIMIT_MAX_PER_MINUTE=30
RATE_LIMIT_MAX_PER_HOUR=100
AGENTCASH_HOME_ROOT=data/agentcash-homes
OPENAI_API_KEY=
OPENAI_ROUTER_MODEL=gpt-5.4-mini
ANTHROPIC_API_KEY=
ANTHROPIC_ROUTER_MODEL=claude-sonnet-4-20250514
ROUTER_CONFIDENCE_THRESHOLD=0.75
ROUTER_TIMEOUT_MS=10000
# Must be a base64 string that decodes to exactly 32 bytes.
# Generate with: openssl rand -base64 32
MASTER_ENCRYPTION_KEY=replace-with-32-byte-base64-key
